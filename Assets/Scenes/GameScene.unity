  player: {fileID: 71417367}
  bucket: {fileID: 37985320}
  fontSize: 52
  textColor: {r: 1, g: 1, b: 1, a: 1}
  step1Text: "Hos Geldin!\n\nHareket etmek icin A / D veya \u2190 \u2192 tu\u015Flar\u0131n\u0131
    kullan.\n\nBiraz hareket et!"
  step2Text: "Harika!\n\nSimdi dur ve yagmur damlalar\u0131n\u0131n kovana dolmas\u0131n\u0131
    bekle.\n\n{0} ml su topla!"
  step3Text: "Super!\n\nU tusuna bas ve Upgrade Agac\u0131n\u0131 a\xE7.\n\nDepo
    yukseltmesini sat\u0131n al \u2014\nbu, suyu depolaman\u0131 saglayacak!"
  step4Text: "Mukemmel!\n\nDepona ulasmak icin yan\u0131na git.\nKovan otomatik olarak
    bosalacak.\n\nBiriktirdigin su para kazanmanda kullan\u0131lacak.\n\n\u0130yi
    \u015Fanslar!"
  waterCollectTarget: 10
  forceShowTutorial: 1
  stepDelay: 0.5
  fadeOutDuration: 1
